# Copy this file to /etc/simsexam/simsexam.env and adjust values as needed.

SIMSEXAM_ADDR=127.0.0.1:6080
SIMSEXAM_DB_PATH=/var/lib/simsexam/simsexam_v1.db
SIMSEXAM_IMPORT_SOURCE_TYPE=manual
# Use a random 24-32 character password without spaces.
SIMSEXAM_ADMIN_PASSWORD=change-this-before-production
# Use a long random base64 or hex secret without spaces.
SIMSEXAM_ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret
# Use a separate long random base64 or hex secret for learner login sessions.
SIMSEXAM_USER_SESSION_SECRET=change-this-to-a-different-long-random-secret
# Set to true behind HTTPS so session cookies are marked Secure.
SIMSEXAM_COOKIE_SECURE=true
